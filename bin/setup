#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

BOLD="$(printf '\033[1m')"
GREEN="$(printf '\033[32m')"
YELLOW="$(printf '\033[33m')"
RED="$(printf '\033[31m')"
BLUE="$(printf '\033[34m')"
RESET="$(printf '\033[0m')"

log() {
  printf "%b==>%b %s\n" "$BLUE" "$RESET" "$1"
}

ok() {
  printf "%b✔%b %s\n" "$GREEN" "$RESET" "$1"
}

warn() {
  printf "%b⚠%b %s\n" "$YELLOW" "$RESET" "$1"
}

fail() {
  printf "%b✖%b %s\n" "$RED" "$RESET" "$1" >&2
  exit 1
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    fail "Missing required command: $1"
  fi
}

if [ "${ZEPHIRA_IN_SANDBOX:-}" != "1" ]; then
  warn "ZEPHIRA_IN_SANDBOX is not set to 1."
  warn "Run this inside the container for compatibility with the container Ruby."
  warn "Running on the host can install gems under a different Ruby ABI path, which will not work inside the container."
fi

log "Preparing workspace-persistent development environment"

require_cmd ruby
require_cmd bundle

mkdir -p "$ROOT_DIR/.vendor/bundle"
mkdir -p "$ROOT_DIR/.bundle"
mkdir -p "$ROOT_DIR/.config/irb"

log "Writing local Bundler config"
bundle config set --local path '.vendor/bundle'
bundle config set --local jobs 4
bundle config set --local retry 3
ok "Bundler configured to install gems into $ROOT_DIR/.vendor/bundle"

log "Writing dev shell helper"
cat > "$ROOT_DIR/.env.dev" <<'EOF'
export BUNDLE_PATH="/workspace/.vendor/bundle"
export GEM_HOME="/workspace/.vendor/bundle/ruby/$(ruby -e 'print RbConfig::CONFIG["ruby_version"]')"
export GEM_PATH="$GEM_HOME"
export PATH="/workspace/.vendor/bundle/bin:$GEM_HOME/bin:$PATH"
export IRBRC="/workspace/.config/irb/irbrc"
EOF
ok "Wrote /workspace/.env.dev"

log "Writing IRB config"
cat > "$ROOT_DIR/.config/irb/irbrc" <<'EOF'
IRB.conf[:SAVE_HISTORY] = 1000
IRB.conf[:HISTORY_FILE] = "/workspace/.config/irb/history"
EOF
ok "Wrote /workspace/.config/irb/irbrc"

log "Installing gem dependencies"
bundle install
ok "Bundle install completed"

log "Verifying environment"
ruby -v
bundle -v
bundle exec rspec --version
bundle exec standardrb --version
ok "Core development commands are available"

printf "\n%bSetup complete.%b\n" "$BOLD" "$RESET"
printf "  • Source %b/workspace/.env.dev%b in future shells if you want the persistent gem path exported.\n" "$BOLD" "$RESET"
printf "  • Run %bbin/setup%b inside the container for compatibility with the container Ruby.\n" "$BOLD" "$RESET"
printf "  • Run %bbundle exec rspec%b to execute the test suite.\n" "$BOLD" "$RESET"
printf "  • Run %bbundle exec standardrb%b for linting.\n" "$BOLD" "$RESET"
