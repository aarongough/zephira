#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

ruby -I"$REPO_ROOT/lib" \
  -r zephira/config \
  -r zephira/formatter \
  -r zephira/onboarding \
  -e 'Zephira::Onboarding.run_if_needed!'

exec "$SCRIPT_DIR/docker-shell" 'bin/setup && source /workspace/.env.dev && bundle exec ruby exe/zephira'
