#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE_TAG="${ZEPHIRA_DEV_IMAGE:-zephira-dev}"
HOST_UID="$(id -u)"
HOST_GID="$(id -g)"

"$SCRIPT_DIR/docker-build"

DOCKER_ARGS=(
  --rm
  -it
  --user "${HOST_UID}:${HOST_GID}"
  -e HOME=/tmp/zephira-home
  -e ZEPHIRA_IN_SANDBOX=1
  -v "$PWD:/workspace"
  -w /workspace
)

if [ -f "$HOME/.zephira.yml" ]; then
  DOCKER_ARGS+=( -v "$HOME/.zephira.yml:/tmp/zephira-home/.zephira.yml:ro" )
fi

if [ -d "$HOME/.zephira" ]; then
  DOCKER_ARGS+=( -v "$HOME/.zephira:/tmp/zephira-home/.zephira:rw" )
fi

if [ "$#" -eq 0 ]; then
  exec docker run "${DOCKER_ARGS[@]}" "$IMAGE_TAG" bash
else
  exec docker run "${DOCKER_ARGS[@]}" "$IMAGE_TAG" bash -lc "$*"
fi
